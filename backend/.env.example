# GroundControl AI — Environment Variables
# Copy this to .env and fill in secrets

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://groundcontrol:groundcontrol_secret@localhost:5432/groundcontrol

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format)
# ALLOWED_ORIGINS=["http://localhost:3000"]

# ── OpenSky Network (optional — rate-limited free tier) ───────
# Leave blank to use anonymous access (250 requests/day)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Mapbox (optional — for react-map-gl satellite tiles) ──────
MAPBOX_ACCESS_TOKEN=
